// WASI single-threaded stub for <shared_mutex>.
// wasi-sdk-24's libc++ is built without thread support, so the real
// <shared_mutex> refuses to compile. numpy's dispatching.cpp and
// npy_hashtable.cpp use shared_mutex to protect the ufunc dispatch
// cache from concurrent access — irrelevant on single-threaded WASI.
#ifndef _WASI_SHIM_SHARED_MUTEX
#define _WASI_SHIM_SHARED_MUTEX

namespace std {

class shared_mutex {
public:
    void lock() {}
    bool try_lock() { return true; }
    void unlock() {}
    void lock_shared() {}
    bool try_lock_shared() { return true; }
    void unlock_shared() {}
};

template <class Mutex>
class shared_lock {
public:
    shared_lock() = default;
    explicit shared_lock(Mutex&) {}
    ~shared_lock() {}
    void lock() {}
    bool try_lock() { return true; }
    void unlock() {}
    Mutex* release() { return nullptr; }
    bool owns_lock() const { return true; }
    explicit operator bool() const { return true; }
};

} // namespace std

#endif
