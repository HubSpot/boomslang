  private def buildContainerArtifact(
      name: String,
      image: String,
      contextSpecs: Seq[CopySpec],
      contextRefs: Seq[PathRef],
      cli: String,
      dest: os.Path,
      vendorTgzs: Map[String, PathRef] = Map.empty
  ): PathRef = {
    val ctx = dest / "context"
    stageSpecs(ctx, contextSpecs, contextRefs)

    os.remove.all(ctx / "vendor")
    os.makeDir.all(ctx / "vendor")
    for ((vendorName, tgz) <- vendorTgzs) {
      os.copy.over(tgz.path, ctx / "vendor" / vendorName, createFolders = true)
    }

    val out = dest / "out"
    os.remove.all(out)
    os.makeDir.all(out)

    requireContainerCli(cli)
    println(s"$name: using container engine $cli")
    if (isAppleContainerCli(cli)) {
      runLogged((
        "container", "build",
        "--progress", "plain",
        "-t", image,
        "-o", s"type=local,dest=$out",
        "."
      ), cwd = ctx)
      val artifact = os.walk(out).find(_.last == "artifact.tgz")
        .getOrElse(sys.error(s"$name did not produce artifact.tgz"))
      os.copy.over(artifact, dest / "artifact.tgz")
    } else {
      dockerBuild(cli, image, ctx)
      dockerCopyFromImage(cli, image, "/artifact.tgz", dest / "artifact.tgz")
    }

    PathRef(dest / "artifact.tgz")
  }

  def pydanticCoreWasi = Task {
    buildContainerArtifact(
      "pydantic-core-wasi",
      "boomslang-pydantic-core-wasi",
      pydanticCoreWasiSpecs,
