    buildContainerArtifact(
      "cpython-wasi",
      "boomslang-cpython-wasi",
      cpythonWasiSpecs,
      cpythonWasiContext(),
      containerCli(),
      Task.dest,
      Map(
        "pydantic-core-wasi.tgz" -> pydanticCoreWasi(),
        "numpy-wasi.tgz" -> numpyWasi(),
        "pandas-wasi.tgz" -> pandasWasi(),
        "matplotlib-wasi.tgz" -> matplotlibWasi(),
        "pillow-wasi.tgz" -> pillowWasi(),
        "ijson-wasi.tgz" -> ijsonWasi()
      )
    )
  }

  def cpythonWasi = Task {
    val extracted = Task.dest / "extracted"
    os.makeDir.all(extracted)
    runLogged(("tar", "xzf", cpythonWasiTgz().path, "-C", extracted))
    PathRef(extracted)
  }

  def pipPackages = Task {
    val downloadDir = Task.dest / "downloads"
    val extractedDir = Task.dest / "extracted"
    val packagesDir = Task.dest / "pip-packages"
    os.makeDir.all(downloadDir)
    os.makeDir.all(extractedDir)
    os.makeDir.all(packagesDir)

    runLogged((
      defaultPython, "-m", "pip", "download",
      "pydantic==2.12.5",
      "annotated-types>=0.6.0",
      "typing-extensions>=4.14.1",
      "typing-inspection>=0.4.2",
      "--no-deps",
      "-d", downloadDir,
      "--quiet"
    ), env = Map("PIP_DISABLE_PIP_VERSION_CHECK" -> "1"))

    for (wheel <- os.list(downloadDir) if wheel.ext == "whl") {
      runLogged((defaultPython, "-m", "zipfile", "-e", wheel, extractedDir))
    }

    for (pkg <- Seq("pydantic", "annotated_types", "typing_inspection")) {
      val src = extractedDir / pkg
      if (os.exists(src)) copyPath(src, packagesDir / pkg)
    }
    val typingExtensions = extractedDir / "typing_extensions.py"
    if (os.exists(typingExtensions)) os.copy.over(typingExtensions, packagesDir / "typing_extensions.py")

    PathRef(packagesDir)
  }

  def builderImage = Task {
    val ctx = Task.dest / "context"
    stageSpecs(ctx, builderImageSpecs, builderImageContext())
    val cli = containerCli()

    requireContainerCli(cli)
    println(s"builder-image: using container engine $cli")
    if (isAppleContainerCli(cli)) {
      runLogged(("container", "build", "--progress", "plain", "-t", "boomslang-builder", "."), cwd = ctx)
    } else {
      dockerBuild(cli, "boomslang-builder", ctx)
    }

    os.write.over(Task.dest / "image.txt", "boomslang-builder\n")
    PathRef(Task.dest / "image.txt")
  }

  def wasm = Task {
    builderImage()

    val ctx = Task.dest / "context"
    stageSpecs(ctx, wasmSpecs, wasmContext())
    copyPath(cpythonWasi().path, ctx / "cpython-wasi")
    os.makeDir.all(ctx / "lib")
    copyPath(pydanticCorePython().path, ctx / "lib" / "pydantic_core")
    copyPath(pipPackages().path, ctx / "pip-packages")
    os.write.over(
      ctx / "Dockerfile",
      """ARG BUILDER_IMAGE=boomslang-builder
        |FROM ${BUILDER_IMAGE}
        |WORKDIR /build
        |
        |COPY cpython-wasi/ cpython/build/cpython-wasi/
        |COPY lib/ cpython/lib/
        |COPY pip-packages/ cpython/lib/pip-packages/
        |COPY python-host/ python-host/
        |COPY python-host-core/ python-host-core/
        |COPY extensions/ extensions/
        |COPY boomslang-hostgen/ boomslang-hostgen/
        |
        |RUN cd python-host && chmod +x build-wasm.sh && ./build-wasm.sh all
        |
        |FROM scratch
        |COPY --from=0 /build/cpython/build/output/boomslang.wasm /boomslang.wasm
        |""".stripMargin
    )

    val out = Task.dest / "out"
    os.makeDir.all(out)
    val cli = containerCli()
    requireContainerCli(cli)
    println(s"boomslang-wasm: using container engine $cli")
    if (isAppleContainerCli(cli)) {
      runLogged(("container", "build", "--progress", "plain", "-t", "boomslang-wasm", "-o", s"type=local,dest=$out", "."), cwd = ctx)
      val wasmArtifact = os.walk(out).find(_.last == "boomslang.wasm")
        .getOrElse(sys.error("boomslang-wasm did not produce boomslang.wasm"))
      os.copy.over(wasmArtifact, Task.dest / "boomslang.wasm")
    } else {
      dockerBuild(cli, "boomslang-wasm", ctx)
      dockerCopyFromImage(cli, "boomslang-wasm", "/boomslang.wasm", Task.dest / "boomslang.wasm")
    }

    PathRef(Task.dest / "boomslang.wasm")
  }

  def resources = Task {
    val pythonRoot = Task.dest / "python"
    val libRoot = pythonRoot / "usr" / "local" / "lib"
    val siteRoot = libRoot / "python3.14"
    os.makeDir.all(libRoot)
    copyPath(cpythonWasi().path / "usr" / "local" / "lib" / "python3.14", siteRoot)
    copyPath(pydanticCorePython().path, siteRoot / "pydantic_core")

    for (pkg <- Seq("pydantic", "annotated_types", "typing_inspection")) {
      val src = pipPackages().path / pkg
      if (os.exists(src)) copyPath(src, siteRoot / pkg)
    }
    val typingExtensions = pipPackages().path / "typing_extensions.py"
    if (os.exists(typingExtensions)) os.copy.over(typingExtensions, siteRoot / "typing_extensions.py")

    copyPathMerge(hostBridgePython().path, siteRoot)
    PathRef(pythonRoot)
  }

  def installPydanticCoreWasi() = Task.Command {
    installCopy(pydanticCoreWasi().path, "cpython/pydantic-core-wasi/artifact.tgz")
  }

  def installNumpyWasi() = Task.Command {
    installCopy(numpyWasi().path, "cpython/numpy-wasi/artifact.tgz")
  }

  def installPandasWasi() = Task.Command {
    installCopy(pandasWasi().path, "cpython/pandas-wasi/artifact.tgz")
  }

  def installMatplotlibWasi() = Task.Command {
    installCopy(matplotlibWasi().path, "cpython/matplotlib-wasi/artifact.tgz")
  }

  def installPillowWasi() = Task.Command {
    installCopy(pillowWasi().path, "cpython/pillow-wasi/artifact.tgz")
  }

  def installIjsonWasi() = Task.Command {
    installCopy(ijsonWasi().path, "cpython/ijson-wasi/artifact.tgz")
  }

  def installNativeTgzs() = Task.Command {
    installCopy(pydanticCoreWasi().path, "cpython/pydantic-core-wasi/artifact.tgz")
    installCopy(numpyWasi().path, "cpython/numpy-wasi/artifact.tgz")
    installCopy(pandasWasi().path, "cpython/pandas-wasi/artifact.tgz")
    installCopy(matplotlibWasi().path, "cpython/matplotlib-wasi/artifact.tgz")
    installCopy(pillowWasi().path, "cpython/pillow-wasi/artifact.tgz")
    installCopy(ijsonWasi().path, "cpython/ijson-wasi/artifact.tgz")
  }

  def installCpythonWasi() = Task.Command {
    installCopy(cpythonWasiTgz().path, "cpython/cpython-wasi/artifact.tgz")
    BuildCtx.withFilesystemCheckerDisabled {
      val dest = BuildCtx.workspaceRoot / "cpython" / "build" / "cpython-wasi"
      os.remove.all(dest)
      copyPath(cpythonWasi().path, dest)
    }
  }

  def installPipPackages() = Task.Command {
    BuildCtx.withFilesystemCheckerDisabled {
      val dest = BuildCtx.workspaceRoot / "cpython" / "lib" / "pip-packages"
      os.remove.all(dest)
      copyPath(pipPackages().path, dest)
    }
  }

  def installWasm() = Task.Command {
    installCopy(wasm().path, s"$runtimeResources/bin/boomslang.wasm")
  }

  def installResources() = Task.Command {
    BuildCtx.withFilesystemCheckerDisabled {
      val dest = pathUnder(BuildCtx.workspaceRoot, runtimeResources) / "usr"
      os.remove.all(dest)
      copyPath(resources().path / "usr", dest)
    }
  }

  def installAll() = Task.Command {
    installCopy(pydanticCoreWasi().path, "cpython/pydantic-core-wasi/artifact.tgz")
    installCopy(numpyWasi().path, "cpython/numpy-wasi/artifact.tgz")
    installCopy(pandasWasi().path, "cpython/pandas-wasi/artifact.tgz")
    installCopy(matplotlibWasi().path, "cpython/matplotlib-wasi/artifact.tgz")
    installCopy(pillowWasi().path, "cpython/pillow-wasi/artifact.tgz")
    installCopy(ijsonWasi().path, "cpython/ijson-wasi/artifact.tgz")
    installCopy(cpythonWasiTgz().path, "cpython/cpython-wasi/artifact.tgz")
    BuildCtx.withFilesystemCheckerDisabled {
      val cpythonDest = BuildCtx.workspaceRoot / "cpython" / "build" / "cpython-wasi"
      os.remove.all(cpythonDest)
      copyPath(cpythonWasi().path, cpythonDest)

      val pipDest = BuildCtx.workspaceRoot / "cpython" / "lib" / "pip-packages"
      os.remove.all(pipDest)
      copyPath(pipPackages().path, pipDest)

      val resourcesDest = pathUnder(BuildCtx.workspaceRoot, runtimeResources) / "usr"
      os.remove.all(resourcesDest)
      copyPath(resources().path / "usr", resourcesDest)
    }
    installCopy(wasm().path, s"$runtimeResources/bin/boomslang.wasm")
  }
}

def build() = Task.Command {
  runLoggedSeq(mavenCommand("clean", "package", "-DskipTests"), cwd = BuildCtx.workspaceRoot)
}

def test() = Task.Command {
  runLoggedSeq(mavenCommand("test", "-pl", "tests"), cwd = BuildCtx.workspaceRoot)
}
