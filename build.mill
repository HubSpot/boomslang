//| mill-version: 1.1.6-88-655739

package build

import mill.*
import mill.api.BuildCtx

private final case class CopySpec(src: String, dest: String)

private def pathUnder(root: os.Path, rel: String): os.Path =
  rel.split('/').filter(_.nonEmpty).foldLeft(root)(_ / _)

private def copyPath(src: os.Path, dest: os.Path): Unit = {
  os.makeDir.all(dest / os.up)
  if (os.isDir(src)) {
    os.remove.all(dest)
    os.copy.over(src, dest, createFolders = true)
  }
  else os.copy.over(src, dest, createFolders = true)
}

private def copyPathMerge(src: os.Path, dest: os.Path): Unit = {
  if (os.isDir(src)) {
    os.makeDir.all(dest)
    for (child <- os.list(src)) copyPathMerge(child, dest / child.last)
  } else {
    copyPath(src, dest)
  }
}

private def specs(base: String, entries: Seq[String]): Seq[CopySpec] =
  entries.map(entry => CopySpec(s"$base/$entry", entry))

private def stageSpecs(dest: os.Path, entries: Seq[CopySpec], refs: Seq[PathRef]): Unit = {
  os.remove.all(dest)
  os.makeDir.all(dest)
  for ((spec, ref) <- entries.zip(refs)) copyPath(ref.path, pathUnder(dest, spec.dest))
}

private def installCopy(src: os.Path, relDest: String): Unit =
  BuildCtx.withFilesystemCheckerDisabled {
    copyPath(src, pathUnder(BuildCtx.workspaceRoot, relDest))
  }

private def runLogged(cmd: os.Shellable, cwd: os.Path = os.pwd, env: Map[String, String] = Map.empty): Unit =
  os.call(cmd, cwd = cwd, env = env, stdout = os.Inherit, stderr = os.Inherit)

private def runLoggedSeq(cmd: Seq[String], cwd: os.Path = os.pwd, env: Map[String, String] = Map.empty): Unit =
  os.proc(cmd).call(cwd = cwd, env = env, stdout = os.Inherit, stderr = os.Inherit)

private def mavenCommand(args: String*): Seq[String] =
  Seq("mvn") ++ sys.env.get("MAVEN_TOOLCHAINS_FILE").toSeq.flatMap(path => Seq("--toolchains", path)) ++ args

private val dockerBuildEnv = Map("DOCKER_BUILDKIT" -> "1")

private def isAppleContainerCli(cli: String): Boolean = cli == "container"

private def requireContainerCli(cli: String): Unit =
  if (!isAppleContainerCli(cli) && cli != "docker") {
    sys.error(s"Unsupported BOOMSLANG_CONTAINER_CLI=$cli; expected docker or container")
  }

private def dockerBuild(cli: String, image: String, ctx: os.Path): Unit =
  runLogged((cli, "build", "--progress=plain", "-t", image, "."), cwd = ctx, env = dockerBuildEnv)

private def dockerCopyFromImage(cli: String, image: String, src: String, dest: os.Path): Unit = {
  val cid = os.proc(cli, "create", image, "unused-cmd").call().out.text().trim
  try runLogged((cli, "cp", s"$cid:$src", dest))
  finally runLogged((cli, "rm", cid))
}

